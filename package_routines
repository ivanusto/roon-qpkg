# Roon Server (Docker) QPKG installation routines (QDK)
#
# The QPKG is a thin shell: management scripts + status UI only.
# No Docker image is bundled — right after installation we ask the
# system container engine (Container Station) to download the official
# RoonLabs image in the background, so App Center stays responsive.
#
# NOTE: QPKG_NAME is "RoonServerDocker" on purpose. QNAP's store carries
# an app named "RoonServer"; sharing that internal name makes App Center
# treat this package as the same app and force-"update" over it.

######### Uninstall routines (embedded into the uninstall script) #########

PKG_PRE_REMOVE="{
    # Stop and remove the containers; the Roon database is kept on disk.
    ${SYS_QPKG_DIR}/roon-server-docker.sh remove >/dev/null 2>&1 || true
}"

PKG_MAIN_REMOVE="{
    true
}"

PKG_POST_REMOVE="{
    /sbin/write_log \"[RoonServerDocker] Removed. Your Roon database was kept on disk; delete the RoonServer data folder manually if you no longer need it.\" 4
}"

######### Install routines #########

pkg_init(){
    true
}

pkg_check_requirement(){
    # QPKG_REQUIRE already enforces Container Station; double-check the
    # docker CLI is actually reachable and fail early with a clear hint.
    CS_DIR=$(/sbin/getcfg container-station Install_Path -f /etc/config/qpkg.conf 2>/dev/null)
    if [ -z "$CS_DIR" ]; then
        err_log "Container Station is required but not installed. Please install Container Station from App Center first."
    fi
}

pkg_pre_install(){
    true
}

pkg_install(){
    true
}

pkg_post_install(){
    # Keep an existing configuration across re-installs/upgrades.
    if [ ! -f "${SYS_QPKG_DIR}/roon.conf" ]; then
        cp "${SYS_QPKG_DIR}/roon.conf.default" "${SYS_QPKG_DIR}/roon.conf"
    fi
    chmod +x "${SYS_QPKG_DIR}/roon-server-docker.sh"
    mkdir -p "${SYS_QPKG_DIR}/logs"

    # Warn (don't abort) if the status-page port is already taken.
    if netstat -lnt 2>/dev/null | grep -q ":18630 "; then
        /sbin/write_log "[RoonServerDocker] Port 18630 is already in use. Set ROON_UI_PORT in ${SYS_QPKG_DIR}/roon.conf to a free port before starting the app." 2
    fi

    # Kick off the image download in the background via the system
    # container engine — installation returns immediately, Roon Server
    # starts by itself once the image is ready. "bgpull" detaches with
    # setsid so the download survives App Center reaping this script's
    # process group.
    "${SYS_QPKG_DIR}/roon-server-docker.sh" bgpull

    /sbin/write_log "[RoonServerDocker] Installed. The official Roon image is being downloaded by Container Station in the background. IMPORTANT: keep the container in host network mode, and put the Roon database on an SSD volume — open the app's status page (port 18630) for details." 4
}
